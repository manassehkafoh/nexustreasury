      "name": "Sprint 9-A \u2014 Financial Planning & Budgeting",
      "description": "Budget lifecycle: create, approve, re-forecast, generate report. Closes FIS BSM gap.",
      "item": [
        {
          "name": "Create annual budget (BASE scenario)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/budgets",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"bank-001\",\n  \"fiscalYear\": 2027,\n  \"scenario\": \"BASE\",\n  \"entries\": [\n    {\n      \"businessUnit\": \"FX_TRADING\",\n      \"period\": \"ANNUAL\",\n      \"currency\": \"USD\",\n      \"targetNII\": 5000000,\n      \"targetNIM\": 0.032,\n      \"nonInterestIncome\": 2000000,\n      \"opex\": 1500000,\n      \"rwa\": 80000000,\n      \"capitalAllocated\": 8000000\n    },\n    {\n      \"businessUnit\": \"RETAIL_BANKING\",\n      \"period\": \"ANNUAL\",\n      \"currency\": \"USD\",\n      \"targetNII\": 12000000,\n      \"targetNIM\": 0.028,\n      \"nonInterestIncome\": 1000000,\n      \"opex\": 4000000,\n      \"rwa\": 200000000,\n      \"capitalAllocated\": 20000000\n    }\n  ]\n}"
            }
