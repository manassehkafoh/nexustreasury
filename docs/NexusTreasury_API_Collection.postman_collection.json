    {
      "name": "Sprint 9-B \u2014 RAROC Profitability Analytics",
      "description": "Multi-dimensional RAROC: BU, customer, product, trader, geography. Closes FIS BSM gap.",
      "item": [
        {
          "name": "Generate profitability report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/v1/raroc/report",
