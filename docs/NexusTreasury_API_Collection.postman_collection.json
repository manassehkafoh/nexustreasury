{
  "info": {
    "name": "NexusTreasury Platform API \u2014 Complete Collection",
    "description": "Production-ready collection for all 11 NexusTreasury REST microservices.\nIncludes realistic request bodies, pre-request auth scripts, and test assertions.\n\nQuick Start:\n1. Set environment: baseUrl, accessToken, tenantId\n2. Run Authentication request first\n3. Use folders in sequence for full lifecycle test",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "29ab24d8-a136-4200-b9a3-f67cbc22c874",
    "uid": "24370565-29ab24d8-a136-4200-b9a3-f67cbc22c874"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4001/api/v1",
      "description": "Trade Service base URL"
    },
    {
      "key": "baseUrl_risk",
      "value": "http://localhost:4003/api/v1",
      "description": "Risk Service"
    },
    {
      "key": "baseUrl_alm",
      "value": "http://localhost:4004/api/v1",
      "description": "ALM Service"
    },
    {
      "key": "baseUrl_bo",
      "value": "http://localhost:4005/api/v1",
      "description": "BO Service"
    },
    {
      "key": "baseUrl_accounting",
      "value": "http://localhost:4007/api/v1",
      "description": "Accounting Service"
    },
    {
      "key": "baseUrl_audit",
      "value": "http://localhost:4008/api/v1",
      "description": "Audit Service"
    },
    {
      "key": "baseUrl_reporting",
      "value": "http://localhost:4011/api/v1",
      "description": "Reporting Service"
    },
    {
      "key": "accessToken",
      "value": "",
      "description": "JWT from Keycloak \u2014 run Auth request first"
    },
    {
      "key": "tradeId",
      "value": "",
      "description": "Auto-populated by Book Trade"
    },
    {
      "key": "tenantId",
      "value": "bank-001"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "type": "string",
        "value": "{{accessToken}}"
      }
    ]
  },
  "item": [
    {
      "name": "\ud83d\udd10 Authentication",
      "item": [
        {
          "name": "Get JWT Token (Keycloak)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', body.access_token);",
                  "console.log('Token acquired. Expires in:', body.expires_in, 'seconds');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{keycloakUrl}}/realms/nexustreasury-{{tenantId}}/protocol/openid-connect/token",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password"
                },
                {
                  "key": "client_id",
                  "value": "nexustreasury-web"
                },
                {
                  "key": "username",
                  "value": "{{adminEmail}}"
                },
                {
                  "key": "password",
                  "value": "{{adminPassword}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "\ud83d\udcc8 Trades",
      "item": [
        {
          "name": "Book FX Forward Trade",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 \u2014 trade booked', () => pm.response.to.have.status(201));",
                  "pm.test('Reference starts with FX-', () => {",
                  "  const b = pm.response.json();",
                  "  pm.expect(b.reference).to.match(/^FX-/);",
                  "  pm.collectionVariables.set('tradeId', b.tradeId);",
                  "});",
                  "pm.test('Status is PENDING_VALIDATION', () => pm.expect(pm.response.json().status).to.equal('PENDING_VALIDATION'));",
                  "pm.test('Response time < 200ms', () => pm.expect(pm.response.responseTime).to.be.below(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/trades",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"assetClass\": \"FX\",\n  \"instrumentType\": \"FORWARD\",\n  \"direction\": \"BUY\",\n  \"notional\": 1000000,\n  \"currency\": \"EUR\",\n  \"counterpartyCurrency\": \"USD\",\n  \"price\": 1.0842,\n  \"counterpartyId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n  \"bookId\": \"fx-prop-desk\",\n  \"traderId\": \"trader-alex-01\",\n  \"valueDate\": \"2026-04-11\"\n}"
            }
          }
        },
        {
          "name": "List Trades (Blotter)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Returns trades array', () => pm.expect(pm.response.json().trades).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/trades?assetClass=FX&limit=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "trades"
              ],
              "query": [
                {
                  "key": "assetClass",
                  "value": "FX"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "\u26a1 Risk",
      "item": [
        {
          "name": "Pre-Deal Check (P99 < 5ms)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 or 422', () => pm.expect([200, 422]).to.include(pm.response.code));",
                  "pm.test('Has approved boolean', () => pm.expect(pm.response.json()).to.have.property('approved'));",
                  "pm.test('Response time < 10ms', () => pm.expect(pm.response.responseTime).to.be.below(10));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl_risk}}/risk/pre-deal-check",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"counterpartyId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n  \"requestedAmount\": 5000000,\n  \"requestedCurrency\": \"USD\"\n}"
            }
          }
        },
        {
          "name": "Historical VaR (Basel III 99%)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('var1Day > 0', () => pm.expect(b.var1Day).to.be.greaterThan(0));",
                  "pm.test('var10Day \u2248 var1Day \u00d7 \u221a10', () => pm.expect(b.var10Day).to.be.closeTo(b.var1Day * Math.sqrt(10), 0.1));",
                  "pm.test('ES \u2265 VaR', () => pm.expect(b.expectedShortfall).to.be.at.least(b.var1Day));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl_risk}}/risk/var/historical",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"pnlHistory\": [\n    {\"date\": \"2026-01-02\", \"pnl\": 12500, \"currency\": \"USD\"},\n    {\"date\": \"2026-01-03\", \"pnl\": -82000, \"currency\": \"USD\"},\n    {\"date\": \"2026-01-04\", \"pnl\": 31000, \"currency\": \"USD\"}\n  ],\n  \"confidence\": 0.99,\n  \"currency\": \"USD\"\n}"
            }
          }
        },
        {
          "name": "FRTB SA Capital (BCBS 457)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('totalCapital \u2265 0', () => pm.expect(b.totalCapital).to.be.at.least(0));",
                  "pm.test('5 risk classes', () => pm.expect(b.byRiskClass).to.have.lengthOf(5));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl_risk}}/risk/frtb/sa",
            "header": [
              {
