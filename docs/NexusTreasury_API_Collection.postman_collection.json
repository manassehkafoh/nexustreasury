        {
          "name": "Historical VaR (Basel III 99%)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('var1Day > 0', () => pm.expect(b.var1Day).to.be.greaterThan(0));",
                  "pm.test('var10Day \u2248 var1Day \u00d7 \u221a10', () => pm.expect(b.var10Day).to.be.closeTo(b.var1Day * Math.sqrt(10), 0.1));",
                  "pm.test('ES \u2265 VaR', () => pm.expect(b.expectedShortfall).to.be.at.least(b.var1Day));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl_risk}}/risk/var/historical",
