    {
      "name": "\ud83d\udd0d Audit Trail",
      "item": [
        {
          "name": "Search Audit Records (SOC 2)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('Has records array', () => pm.expect(b.records).to.be.an('array'));",
                  "pm.test('Each record has 64-char HMAC checksum', () => { b.records.forEach(r => pm.expect(r.checksum).to.match(/^[0-9a-f]{64}$/)); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl_audit}}/audit/records?category=TRADE&severity=CRITICAL&limit=20",
              "host": [
                "{{baseUrl_audit}}"
              ],
              "path": [
                "audit",
                "records"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "TRADE"
                },
                {
                  "key": "severity",
                  "value": "CRITICAL"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        }
      ]
