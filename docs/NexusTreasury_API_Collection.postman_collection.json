  "item": [
    {
      "name": "\ud83d\udd10 Authentication",
      "item": [
        {
          "name": "Get JWT Token (Keycloak)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', body.access_token);",
                  "console.log('Token acquired. Expires in:', body.expires_in, 'seconds');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{keycloakUrl}}/realms/nexustreasury-{{tenantId}}/protocol/openid-connect/token",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password"
                },
                {
                  "key": "client_id",
                  "value": "nexustreasury-web"
                },
                {
                  "key": "username",
                  "value": "{{adminEmail}}"
                },
                {
                  "key": "password",
                  "value": "{{adminPassword}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "\ud83d\udcc8 Trades",
      "item": [
        {
          "name": "Book FX Forward Trade",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 \u2014 trade booked', () => pm.response.to.have.status(201));",
                  "pm.test('Reference starts with FX-', () => {",
                  "  const b = pm.response.json();",
                  "  pm.expect(b.reference).to.match(/^FX-/);",
                  "  pm.collectionVariables.set('tradeId', b.tradeId);",
                  "});",
                  "pm.test('Status is PENDING_VALIDATION', () => pm.expect(pm.response.json().status).to.equal('PENDING_VALIDATION'));",
                  "pm.test('Response time < 200ms', () => pm.expect(pm.response.responseTime).to.be.below(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/trades",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"assetClass\": \"FX\",\n  \"instrumentType\": \"FORWARD\",\n  \"direction\": \"BUY\",\n  \"notional\": 1000000,\n  \"currency\": \"EUR\",\n  \"counterpartyCurrency\": \"USD\",\n  \"price\": 1.0842,\n  \"counterpartyId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n  \"bookId\": \"fx-prop-desk\",\n  \"traderId\": \"trader-alex-01\",\n  \"valueDate\": \"2026-04-11\"\n}"
            }
          }
        },
        {
          "name": "List Trades (Blotter)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Returns trades array', () => pm.expect(pm.response.json().trades).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/trades?assetClass=FX&limit=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "trades"
              ],
              "query": [
                {
                  "key": "assetClass",
                  "value": "FX"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        }
      ]
    },
