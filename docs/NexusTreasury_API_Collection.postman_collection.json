              },
              "raw": "{\n  \"sensitivities\": [\n    {\"positionId\": \"p1\", \"riskClass\": \"GIRR\", \"bucket\": \"USD\", \"riskFactor\": \"5Y\", \"sensitivity\": -5000, \"currency\": \"USD\"},\n    {\"positionId\": \"p2\", \"riskClass\": \"FX\", \"bucket\": \"1\", \"riskFactor\": \"EURUSD\", \"sensitivity\": 500000, \"currency\": \"USD\"},\n    {\"positionId\": \"p3\", \"riskClass\": \"EQUITY\", \"bucket\": \"1\", \"riskFactor\": \"SPOT\", \"sensitivity\": 200000, \"currency\": \"USD\"}\n  ],\n  \"currency\": \"USD\"\n}"
            }
