{
  "name": "nexustreasury",
  "version": "1.0.0",
  "private": true,
  "description": "NexusTreasury — Cloud-Native Treasury Management Platform",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "infra:apply": "cd infra && kubectl apply -k kubernetes/overlays/production",
    "infra:staging": "cd infra && kubectl apply -k kubernetes/overlays/staging",
    "db:migrate": "prisma migrate dev",
    "db:seed": "turbo run db:seed",
    "db:generate": "prisma generate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prisma": "^5.9.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "react": "^18.3.1",
      "react-dom": "^18.3.1"
    }
  },
  "dependencies": {
    "@prisma/client": "^5.9.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
