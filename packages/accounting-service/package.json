    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@prisma/client": "^5.9.0",
    "fastify": "^5.8.3",
    "fastify-plugin": "^4.5.1",
    "kafkajs": "^2.2.4",
    "ioredis": "^5.3.2",
    "pino": "^8.18.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "vitest": "^1.0.0"
