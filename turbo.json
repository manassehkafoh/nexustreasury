{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "test:coverage": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "@nexustreasury/domain#build": {
      "outputs": [
        "dist/**"
      ],
      "cache": true
    },
    "@nexustreasury/position-service#build": {
      "dependsOn": [
        "@nexustreasury/domain#build"
      ],
      "outputs": [
        "dist/**"
      ],
      "cache": true
    },
    "@nexustreasury/trade-service#build": {
      "dependsOn": [
        "@nexustreasury/domain#build"
      ],
      "outputs": [
        "dist/**"
      ],
      "cache": true
    },
    "@nexustreasury/risk-service#build": {
      "dependsOn": [
        "@nexustreasury/domain#build"
      ],
      "outputs": [
        "dist/**"
      ],
      "cache": true
    },
    "@nexustreasury/alm-service#build": {
      "dependsOn": [
        "@nexustreasury/domain#build"
      ],
      "outputs": [
        "dist/**"
      ],
      "cache": true
    },
    "@nexustreasury/bo-service#build": {
      "dependsOn": [
        "@nexustreasury/domain#build"
      ],
      "outputs": [
        "dist/**"
      ],
      "cache": true
    },
    "@nexustreasury/market-data-service#build": {
      "dependsOn": [
        "@nexustreasury/domain#build"
      ],
      "outputs": [
        "dist/**"
      ],
      "cache": true
    }
  }
}
